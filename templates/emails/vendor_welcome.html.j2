{% extends "base_email.html.j2" %}
{% set subject = subject|default("Welcome to Nextou Partner Hub") %}
{% set preheader = preheader|default("Your store is one step closer to going live.") %}
{% set footer_description = footer_description|default("Powering local stores. Delivering happiness.") %}
{% set email_reason = email_reason|default("You’re receiving this email because you signed up as a vendor on Nextou.") %}
{% block hero %}<table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="margin-top:42px;"><tr><td style="width:58%;vertical-align:middle;"><div style="font-size:34px;line-height:1.08;font-weight:800;color:#fff;">Welcome to<br><span style="font-size:48px;">Nextou<br><span style="color:#ffdd36;">Partner Hub</span></span></div><p style="margin:18px 0 0;font-size:18px;line-height:1.5;color:#eee8ff;">{{ vendor_name|default("Your store") }} is now one step closer to going live.</p></td><td align="right" style="width:42%;vertical-align:middle;"><div style="font-size:118px;line-height:1;">🏪</div></td></tr></table>{% endblock %}
{% block content %}
<table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="margin-top:-54px;background:#fff;border-radius:22px;box-shadow:0 14px 38px rgba(35,20,80,.12);"><tr><td style="padding:26px;text-align:center;"><h2 style="margin:0 0 18px;font-size:20px;">Everything you need to manage and grow</h2><table role="presentation" width="100%" cellspacing="0" cellpadding="0"><tr>{% for item in benefits|default([{"icon":"🛒","title":"Manage catalog","text":"Add and update products, prices, and availability."},{"icon":"📍","title":"Track orders","text":"Monitor orders, deliveries, and customer updates in real time."},{"icon":"📣","title":"Grow with promotions","text":"Run offers and attract more customers to your store."}]) %}<td align="center" style="width:33.33%;padding:8px 18px;{% if not loop.last %}border-right:1px solid #eeeafb;{% endif %}"><div style="font-size:48px;margin-bottom:10px;">{{ item.icon }}</div><div style="font-weight:800;font-size:15px;">{{ item.title }}</div><p style="margin:8px 0 0;color:#6f7190;font-size:13px;line-height:1.45;">{{ item.text }}</p></td>{% endfor %}</tr></table></td></tr></table>
<table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="margin-top:24px;background:#f6f1ff;border:1px solid #ded2ff;border-radius:18px;"><tr><td style="padding:26px;text-align:center;"><h2 style="margin:0 0 8px;color:#17152b;">Let’s get your store live 🚀</h2><p style="margin:0 0 22px;color:#6f7190;">Follow these quick steps to complete your onboarding.</p><table role="presentation" width="100%" cellspacing="0" cellpadding="0"><tr>{% for step in onboarding_steps|default([{"icon":"📋","title":"Complete store profile","text":"Add your store details and documents."},{"icon":"🛒","title":"Add products","text":"Upload your catalog and set pricing."},{"icon":"🛵","title":"Set delivery rules","text":"Define delivery areas, time slots, and charges."},{"icon":"✅","title":"Submit for approval","text":"Review and submit your store for activation."}]) %}<td align="center" style="width:25%;padding:8px;"><div style="display:inline-block;background:#fff;border:1px solid #e5ddff;border-radius:16px;padding:14px;min-width:86px;"><div style="font-size:36px;">{{ step.icon }}</div></div><div style="font-weight:800;margin-top:10px;font-size:13px;">{{ step.title }}</div><p style="margin:6px 0 0;color:#6f7190;font-size:12px;line-height:1.4;">{{ step.text }}</p></td>{% endfor %}</tr></table><a href="{{ complete_setup_url|default('#') }}" style="display:inline-block;margin-top:24px;background:linear-gradient(135deg,#5a22f0,#7d43ff);color:#fff;text-decoration:none;border-radius:13px;padding:15px 48px;font-size:16px;font-weight:800;">Complete Setup →</a><div style="margin-top:10px;color:#7a7593;font-size:12px;">🛡 Secure. Verified. Trusted by thousands.</div></td></tr></table>
<table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="margin-top:18px;background:#fbf8ff;border:1px solid #e5ddff;border-radius:16px;"><tr><td style="padding:18px 24px;font-size:42px;width:84px;">🎧</td><td style="padding:18px 0;"><b style="font-size:17px;">We’re here to help!</b><p style="margin:6px 0 0;color:#6f7190;font-size:14px;">Need assistance? Our Partner Support team is ready to help.</p></td><td align="right" style="padding:18px 24px;"><a href="{{ partner_support_url|default('#') }}" style="display:inline-block;border:1px solid #7b4cff;color:#531df0;text-decoration:none;border-radius:12px;padding:12px 20px;font-weight:800;">Contact Support →</a></td></tr></table>
{% endblock %}
