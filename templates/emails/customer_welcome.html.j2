{% extends "base_email.html.j2" %}
{% set subject = subject|default("Welcome to Nextou") %}
{% set preheader = preheader|default("Your instant delivery app is ready.") %}
{% set email_reason = email_reason|default("You’re receiving this email because you recently joined Nextou.") %}
{% block hero %}
<table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="margin-top:42px;"><tr>
<td style="width:58%;vertical-align:middle;"><div style="font-size:34px;line-height:1.08;font-weight:800;letter-spacing:-1px;color:#fff;">Welcome to<br><span style="font-size:52px;">Next<span style="color:#ffdd36;">ou</span></span></div><p style="margin:18px 0 26px;font-size:17px;line-height:1.55;color:#eee8ff;">Your instant delivery app for groceries, essentials, and more — delivered <b style="color:#ffdd36;">in minutes</b>.</p><a href="{{ start_shopping_url|default('#') }}" style="display:inline-block;background:#fff;color:#531df0;font-size:17px;font-weight:800;text-decoration:none;border-radius:16px;padding:16px 30px;">Start Shopping →</a></td>
<td align="right" style="width:42%;vertical-align:middle;"><div style="font-size:112px;line-height:1;">🛍️</div><div style="display:inline-block;background:#fff;border-radius:999px;color:#531df0;font-weight:900;padding:12px 18px;margin-top:8px;">{{ delivery_time|default("20 mins") }}</div></td>
</tr></table>
{% endblock %}
{% block content %}
<table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="margin-top:-48px;background:#fff;border-radius:22px;box-shadow:0 14px 38px rgba(35,20,80,.12);"><tr><td style="padding:26px;text-align:center;"><h2 style="margin:0 0 18px;font-size:19px;color:#17152b;">Why you’ll love {{ brand_name|default("Nextou") }}</h2><table role="presentation" width="100%" cellspacing="0" cellpadding="0"><tr>{% for item in benefits|default([{"icon":"⏱️","title":"Lightning-fast delivery","text":"Get your order in as little as 20 minutes."},{"icon":"📍","title":"Live order tracking","text":"Track your order in real-time from store to your door."},{"icon":"🏷️","title":"Exclusive offers","text":"Enjoy special deals and savings only on Nextou."}]) %}<td align="center" style="width:33.33%;padding:8px 18px;{% if not loop.last %}border-right:1px solid #eeeafb;{% endif %}"><div style="font-size:48px;margin-bottom:10px;">{{ item.icon }}</div><div style="font-weight:800;font-size:15px;color:#17152b;">{{ item.title }}</div><p style="margin:8px 0 0;color:#6f7190;font-size:13px;line-height:1.45;">{{ item.text }}</p></td>{% endfor %}</tr></table></td></tr></table>
<table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="margin-top:24px;background:#f6f1ff;border:1px solid #ded2ff;border-radius:18px;"><tr><td style="padding:26px 30px;width:60%;"><h2 style="margin:0 0 8px;color:#531df0;font-size:24px;">Here’s a little gift for you!</h2><p style="margin:0 0 16px;font-size:17px;color:#17152b;">Enjoy Flat <b>25% OFF</b> on your first order.</p><div style="display:inline-block;border:1px dashed #7b4cff;border-radius:12px;background:#fff;padding:12px 24px;color:#531df0;font-size:18px;">Code: <b>{{ coupon_code|default("NEXTOU25") }}</b></div><p style="margin:10px 0 0;color:#8a86a2;font-size:12px;">{{ coupon_note|default("Valid for a limited time.") }}</p></td><td align="center" style="padding:24px;font-size:84px;">🏷️</td></tr></table>
<h2 style="text-align:center;margin:26px 0 18px;font-size:20px;color:#17152b;">Shop what you need</h2><table role="presentation" width="100%" cellspacing="0" cellpadding="0"><tr>{% for cat in categories|default([{"icon":"🛒","name":"Grocery"},{"icon":"🍔","name":"Food"},{"icon":"🥐","name":"Bakery"},{"icon":"🥤","name":"Drinks"},{"icon":"💊","name":"Pharmacy"},{"icon":"••","name":"More"}]) %}<td align="center" style="padding:8px;"><div style="border:1px solid #eeeafb;border-radius:18px;background:#fff;box-shadow:0 8px 20px rgba(35,20,80,.05);padding:16px 8px;"><div style="font-size:34px;line-height:1.1;">{{ cat.icon }}</div></div><div style="margin-top:8px;font-weight:800;font-size:13px;color:#17152b;">{{ cat.name }}</div></td>{% endfor %}</tr></table>
{% endblock %}
