{% extends "base_email.html.j2" %}
{% set subject = subject|default("New vendor registration received") %}
{% set preheader = preheader|default("A new vendor signed up and is awaiting review.") %}
{% set brand_tagline = brand_tagline|default("Admin Alert ⚡") %}
{% set footer_description = footer_description|default("Fast. Fresh. Delivered. ⚡") %}
{% set email_reason = email_reason|default("You’re receiving this email because you are an admin at Nextou.") %}
{% block hero %}<table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="margin-top:42px;"><tr><td style="width:58%;vertical-align:middle;"><div style="font-size:42px;line-height:1.1;font-weight:800;color:#fff;">New Vendor<br>Registration <span style="color:#ffdd36;">Received</span></div><p style="margin:18px 0 0;font-size:18px;line-height:1.5;color:#eee8ff;">A vendor has signed up and is awaiting review.</p></td><td align="right" style="width:42%;vertical-align:middle;"><div style="font-size:112px;line-height:1;">🏪🔔</div></td></tr></table>{% endblock %}
{% block content %}
<table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="margin-top:-48px;background:#fff;border-radius:22px;box-shadow:0 14px 38px rgba(35,20,80,.12);"><tr><td style="padding:28px;"><table role="presentation" width="100%" cellspacing="0" cellpadding="0"><tr><td><h2 style="margin:0;font-size:22px;">🏪 Vendor Summary</h2></td><td align="right"><span style="display:inline-block;background:#fff2d8;color:#c46c00;border-radius:999px;padding:10px 16px;font-weight:800;">◷ {{ review_status|default("Pending Review") }}</span></td></tr></table><table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="margin-top:24px;">{% for row in vendor_summary|default([{"label":"Vendor Name","value":vendor_name|default("Fresh Basket Mart")},{"label":"Contact","value":vendor_phone|default("+91 98765 43210")},{"label":"Email","value":vendor_email|default("owner@freshbasket.in")},{"label":"City","value":vendor_city|default("Bengaluru")},{"label":"Category","value":vendor_category|default("Grocery")}]) %}<tr><td style="padding:12px 0;border-bottom:1px solid #eeeafb;color:#6f7190;width:34%;">{{ row.label }}</td><td style="padding:12px 0;border-bottom:1px solid #eeeafb;color:#6f7190;width:4%;">:</td><td style="padding:12px 0;border-bottom:1px solid #eeeafb;font-weight:800;color:#17152b;">{{ row.value }}</td></tr>{% endfor %}</table></td></tr></table>
<table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="margin-top:22px;"><tr><td style="padding-right:10px;width:50%;"><a href="{{ review_application_url|default('#') }}" style="display:block;text-align:center;background:linear-gradient(135deg,#5a22f0,#7d43ff);color:#fff;text-decoration:none;border-radius:14px;padding:18px 12px;font-size:17px;font-weight:800;">📋 Review Application →</a></td><td style="padding-left:10px;width:50%;"><a href="{{ admin_panel_url|default('#') }}" style="display:block;text-align:center;background:#fff;color:#531df0;text-decoration:none;border:1px solid #7b4cff;border-radius:14px;padding:17px 12px;font-size:17px;font-weight:800;">▦ Open Admin Panel →</a></td></tr></table>
<table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="margin-top:22px;background:#f6f1ff;border:1px solid #ded2ff;border-radius:18px;"><tr><td style="padding:24px 28px;width:36%;font-size:80px;text-align:center;">🔎</td><td style="padding:24px 28px;"><h2 style="margin:0 0 12px;color:#531df0;">Next Steps</h2><ol style="margin:0;padding-left:20px;color:#17152b;line-height:1.8;">{% for step in next_steps|default(["Verify documents","Check catalog eligibility","Approve or request changes"]) %}<li>{{ step }}</li>{% endfor %}</ol></td><td style="padding:24px 28px;width:28%;font-size:76px;text-align:center;">🛡️</td></tr></table>
{% endblock %}
