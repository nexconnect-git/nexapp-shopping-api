{% extends "base_email.html.j2" %}
{% set subject = subject|default("Your Nextou OTP") %}
{% set preheader = preheader|default("Use this code to verify your login.") %}
{% set email_reason = email_reason|default("You’re receiving this email because you recently signed in to Nextou.") %}
{% block hero %}<table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="margin-top:48px;"><tr><td style="width:58%;vertical-align:middle;"><div style="font-size:42px;line-height:1.12;font-weight:800;color:#fff;">Verify your login</div><p style="margin:18px 0 0;font-size:18px;line-height:1.5;color:#eee8ff;">Use the one-time password below to continue securely.</p></td><td align="right" style="width:42%;vertical-align:middle;"><div style="font-size:112px;line-height:1;">🔐</div></td></tr></table>{% endblock %}
{% block content %}
<table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="margin-top:-48px;background:#fff;border-radius:22px;box-shadow:0 14px 38px rgba(35,20,80,.12);"><tr><td align="center" style="padding:34px 24px;"><h2 style="margin:0 0 22px;color:#6c6a91;font-size:22px;">Your one-time password (OTP)</h2><div style="display:inline-block;background:#f7f3ff;border:1px solid #ded2ff;border-radius:16px;padding:24px 34px;font-size:64px;font-weight:900;color:#531df0;letter-spacing:18px;line-height:1;">{{ otp_code|default("482614") }}</div><p style="margin:22px 0 0;color:#6f7190;font-size:16px;">Enter this code in the Nextou app to verify your login.</p></td></tr></table>
<table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="margin-top:24px;background:#fff;border:1px solid #eeeafb;border-radius:18px;"><tr>{% for item in security_notes|default([{"icon":"⏱️","title":"Valid for 10 minutes","text":"This code will expire in 10 minutes."},{"icon":"🛡️","title":"Do not share this code","text":"For your security, never share this OTP with anyone."},{"icon":"✉️","title":"If you didn’t request this","text":"You can safely ignore this email."}]) %}<td align="center" style="width:33.33%;padding:28px 18px;{% if not loop.last %}border-right:1px solid #eeeafb;{% endif %}"><div style="font-size:42px;">{{ item.icon }}</div><div style="font-weight:800;margin-top:12px;">{{ item.title }}</div><p style="margin:8px 0 0;color:#6f7190;font-size:13px;line-height:1.45;">{{ item.text }}</p></td>{% endfor %}</tr></table>
<div style="text-align:center;margin-top:26px;"><a href="{{ app_url|default('#') }}" style="display:inline-block;background:linear-gradient(135deg,#5a22f0,#7d43ff);color:#fff;text-decoration:none;border-radius:11px;padding:14px 34px;font-size:16px;font-weight:800;">Open Nextou →</a><p style="margin:14px 0 0;color:#6f7190;font-size:14px;">Thanks for choosing Nextou.<br><b>We’re here to make your everyday easier. 💜</b></p></div>
{% endblock %}
