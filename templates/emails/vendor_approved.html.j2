{% extends "base_email.html.j2" %}
{% set subject = subject|default("Your Nextou vendor account is approved") %}
{% set preheader = preheader|default("You are ready to start selling on Nextou.") %}
{% set email_reason = email_reason|default("You’re receiving this email because you’re a vendor on Nextou.") %}
{% block hero %}<table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="margin-top:42px;"><tr><td style="width:56%;vertical-align:middle;"><div style="font-size:42px;line-height:1.08;font-weight:800;color:#fff;">Your Vendor<br>Account Is<br><span style="color:#ffdd36;">Approved!</span></div><p style="margin:18px 0 24px;font-size:18px;line-height:1.5;color:#eee8ff;">You’re now ready to start selling on Nextou.</p><a href="{{ dashboard_url|default('#') }}" style="display:inline-block;background:#fff;color:#531df0;font-size:17px;font-weight:800;text-decoration:none;border-radius:16px;padding:16px 30px;">Go to Dashboard →</a></td><td align="right" style="width:44%;vertical-align:middle;"><div style="font-size:116px;line-height:1;">✅</div></td></tr></table>{% endblock %}
{% block content %}
<table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="margin-top:-48px;background:#f1fff6;border:1px solid #ccefd8;border-radius:18px;"><tr><td style="padding:22px;width:72px;font-size:42px;">✅</td><td style="padding:22px 22px 22px 0;"><b style="font-size:18px;">Congratulations, {{ vendor_name|default("Vendor") }}!</b><p style="margin:6px 0 0;color:#34445a;font-size:14px;line-height:1.5;">Your vendor account has been verified and approved. You can now manage your store, list products, and start receiving orders.</p></td></tr></table>
<table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="margin-top:24px;background:#fff;border:1px solid #eeeafb;border-radius:18px;"><tr><td style="padding:26px;text-align:center;"><h2 style="margin:0 0 18px;">You’re all set to grow with Nextou</h2><table role="presentation" width="100%" cellspacing="0" cellpadding="0"><tr>{% for item in growth_items|default([{"icon":"⚡","title":"Go live instantly","text":"Your store is active and ready to reach customers."},{"icon":"🛍️","title":"Receive orders","text":"Start getting orders from thousands of happy customers."},{"icon":"📈","title":"Track performance","text":"Monitor sales, payouts, and growth in real time."}]) %}<td align="center" style="width:33.33%;padding:8px 18px;{% if not loop.last %}border-right:1px solid #eeeafb;{% endif %}"><div style="font-size:48px;">{{ item.icon }}</div><div style="font-weight:800;margin-top:10px;">{{ item.title }}</div><p style="margin:8px 0 0;color:#6f7190;font-size:13px;line-height:1.45;">{{ item.text }}</p></td>{% endfor %}</tr></table></td></tr></table>
<table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="margin-top:24px;background:#f6f1ff;border:1px solid #ded2ff;border-radius:18px;"><tr><td style="padding:26px;text-align:center;"><h2 style="margin:0 0 8px;">What’s next?</h2><p style="margin:0 0 20px;color:#6f7190;">Follow these simple steps to get the most out of Nextou.</p><table role="presentation" width="100%" cellspacing="0" cellpadding="0"><tr>{% for step in next_steps|default([{"title":"Review store settings","text":"Update your profile, business details, and delivery preferences."},{"title":"Publish products","text":"Add your best products and make them discoverable."},{"title":"Start accepting orders","text":"Turn on your store and start delivering smiles."}]) %}<td align="center" style="width:33.33%;padding:8px;"><div style="background:#fff;border:1px solid #e5ddff;border-radius:16px;padding:18px;"><div style="display:inline-block;background:#5a22f0;color:#fff;border-radius:999px;width:26px;height:26px;line-height:26px;font-weight:800;">{{ loop.index }}</div><h3 style="margin:12px 0 6px;font-size:15px;">{{ step.title }}</h3><p style="margin:0;color:#6f7190;font-size:12px;line-height:1.4;">{{ step.text }}</p></div></td>{% endfor %}</tr></table><a href="{{ dashboard_url|default('#') }}" style="display:inline-block;margin-top:20px;background:linear-gradient(135deg,#5a22f0,#7d43ff);color:#fff;text-decoration:none;border-radius:13px;padding:15px 48px;font-size:16px;font-weight:800;">Go to Dashboard →</a></td></tr></table>
{% endblock %}
