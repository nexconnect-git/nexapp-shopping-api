# Production Environment Variables Example
# Copy this file to .env and adjust the values before deploying to EC2.

# --- Django Core Settings ---
SECRET_KEY=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING_FOR_PRODUCTION
DEBUG=False
ENABLE_DJANGO_RQ_DASHBOARD=False

# Comma-separated list of allowed hostnames (e.g., example.com,www.example.com,SERVER_IP)
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# CORS domains that can access the API. Replace * with specific domains in strict production.
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://yourdomain.com
CORS_ALLOW_CREDENTIALS=True

# --- PostgreSQL Database Setup ---
DB_ENGINE=django.db.backends.postgresql
DB_NAME=nc_shopping_app
DB_USER=postgres
DB_PASSWORD=YOUR_SECURE_DB_PASSWORD
DB_HOST=db
DB_PORT=5432

# --- Redis Setup ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Email Notifications ---
# Set EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend for production
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=YOUR_EMAIL_API_KEY
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@nex-connect.in

# --- Firebase Cloud Messaging (FCM) ---
FIREBASE_SERVICE_ACCOUNT_PATH=/run/secrets/firebase_service_account.json

# --- Auth Hardening ---
ACCESS_TOKEN_LIFETIME_MINUTES=15
REFRESH_TOKEN_LIFETIME_DAYS=7
AUTH_REFRESH_COOKIE_SECURE=True
AUTH_REFRESH_COOKIE_SAMESITE=Lax
INITIAL_SUPERUSER_SETUP_ENABLED=False
INITIAL_SUPERUSER_SETUP_TOKEN=CHANGE_THIS_TO_A_ONE_TIME_BOOTSTRAP_SECRET

# --- Logging Archive (daily per-user folders) ---
APP_LOG_LEVEL=INFO
APP_LOG_DIR=backend/runtime_logs
APP_LOG_FILE_NAME=application.log
ENABLE_S3_LOG_ARCHIVE=True
# Logging uses the same S3 bucket from AWS_STORAGE_BUCKET_NAME.
APP_LOG_S3_PREFIX=logs
APP_LOG_UPLOAD_INTERVAL_SECONDS=30
APP_LOG_TIMEZONE=Asia/Kolkata
APP_LOG_RQ_QUEUE=default
